# Database (SQLite local — no setup needed)
# Note: Prisma Client resolves this from project root (CWD), so ./prisma/dev.db is correct.
# For Prisma CLI (migrate, db push), we override with -D flag in package.json scripts.
DATABASE_URL="file:./prisma/dev.db"

# App
NEXTAUTH_URL="http://localhost:3000"
NODE_ENV="development"

# n8n Webhook (Phase 6)
N8N_WEBHOOK_URL=""
N8N_WEBHOOK_SECRET=""

# Resend (Phase 6)
RESEND_API_KEY=""

# Admin (Phase 8 — simple mock auth)
ADMIN_PASSWORD=""

# Clerk (Phase 10 — do NOT activate now)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""

# Supabase (Phase 10 — do NOT activate now)
DIRECT_URL=""
