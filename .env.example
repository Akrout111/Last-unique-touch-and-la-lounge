# Database
DATABASE_URL="file:./prisma/db/app.db"

# Required in production
ADMIN_PASSWORD=                  # Admin login password (set a strong one)
SESSION_SECRET=                  # REQUIRED (≥32 chars): openssl rand -hex 32
PAYMENT_WEBHOOK_SECRET=          # REQUIRED (≥16 chars): openssl rand -hex 16

# Optional
N8N_WEBHOOK_URL=                 # n8n webhook URL for automation
N8N_WEBHOOK_SECRET=              # HMAC secret for signing n8n webhooks
NEXT_PUBLIC_WHATSAPP_NUMBER=     # WhatsApp number (E.164 format, e.g. 965XXXXXXXX)
NEXT_PUBLIC_PHONE_NUMBER=        # Phone number for display
NEXT_PUBLIC_SITE_URL=            # Canonical site URL (e.g. https://lastuniquetouch.com)

# Infra / security
TRUSTED_PROXY_IPS=               # Comma-separated list of trusted proxy IPs (for XFF parsing)
SESSION_EPOCH=                   # Integer token-revocation epoch (bump to invalidate all sessions)
NODE_ENV=                        # production | development
