# Database (SQLite local — no setup needed)
# Note: This path is resolved from project root (CWD) by Prisma Client at runtime.
# For Prisma CLI (migrate, db push), scripts in package.json override with the correct relative path.
DATABASE_URL="file:./prisma/dev.db"

# App
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NODE_ENV="development"

# n8n Webhook (Phase 6)
N8N_WEBHOOK_URL=""
N8N_WEBHOOK_SECRET=""

# Resend (Phase 6)
RESEND_API_KEY=""

# Admin (Phase 8 — simple mock auth)
ADMIN_PASSWORD=
SESSION_SECRET=

# Webhook / internal API secrets (Phase 1 security)
PAYMENT_WEBHOOK_SECRET=
INTERNAL_API_SECRET=

# Clerk (Phase 10 — do NOT activate now)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""

# Supabase (Phase 10 — do NOT activate now)
DIRECT_URL=""
