# Caddyfile — Gateway for preview panel
#
# The :81 block proxies requests from the preview panel to the Next.js
# server on port 3000. The XTransformPort query parameter is restricted
# to port 3000 only (allowlist) to prevent SSRF attacks.

:81 {
	@allowed query.XTransformPort=3000
	handle @allowed {
		reverse_proxy localhost:3000
	}
	handle {
		respond 403
	}
}
